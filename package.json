{
  "name": "java-runner-client",
  "version": "2.1.0",
  "description": "Run and manage Java processes with profiles, console I/O, and system tray support",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && wait-on http://localhost:5173 && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "dist": "rimraf dist && npm run build && electron-builder",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "uuid": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "terser": "^5.28.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0",
    "rimraf": "^5.0.0"
  },
  "build": {
    "appId": "com.timonmdy.javarunnerclient",
    "productName": "Java Runner Client",
    "icon": "resources/icon",
    "files": ["dist/**/*", "resources/**/*"],
    "win": { "target": "nsis", "icon": "resources/icon.ico" },
    "linux": { "target": "AppImage", "icon": "resources/icon.png" },
    "mac": { "icon": "resources/icon.icns" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  }
}
